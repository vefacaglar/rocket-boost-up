# =============== #
#  Unity .gitignore
# =============== #

# Library & Temp
/[Ll]ibrary/
/[Tt]emp/
/[Oo]bj/
/[Bb]uild/
/[Bb]uilds/
/[Ll]ogs/
/[Uu]ser[Ss]ettings/

# MemoryCaptures
/[Mm]emoryCaptures/

# Recordings
/[Rr]ecordings/

# Asset meta data should only be ignored when using external (visible) version control
# /[Aa]ssets/*.meta

# Autogenerated Crash Reports
sysinfo.txt

# Builds
*.apk
*.aab
*.unitypackage
*.app

# Compressed Archive
*.7z
*.dmg
*.gz
*.iso
*.jar
*.rar
*.tar
*.zip

# ============= #
#  IDE / Editor
# ============= #

# Visual Studio
.vs/
*.csproj
*.unityproj
*.sln
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db

# JetBrains Rider
.idea/
*.sln.iml

# Visual Studio Code
.vscode/
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# MonoDevelop
*.pidb.meta
*.pdb.meta
*.mdb.meta

# ============= #
#  OS Generated
# ============= #

# macOS
.DS_Store
.AppleDouble
.LSOverride
Icon?
._*

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
[Dd]esktop.ini
$RECYCLE.BIN/
*.cab
*.msi
*.msix
*.msm
*.msp
*.lnk

# Linux
*~

# ======================== #
#  Plastic SCM (Ignore.conf)
# ======================== #
/ignore.conf

# ======================== #
#  TextMesh Pro
# ======================== #
/[Aa]ssets/TextMesh*Pro/

# ======================== #
#  Addressables
# ======================== #
/[Aa]ssets/[Aa]ddressable[Aa]ssets[Dd]ata/*/*.bin*
/[Aa]ssets/[Ss]treamingAssets/aa.meta
/[Aa]ssets/[Ss]treamingAssets/aa/*

# ======================== #
#  NuGet
# ======================== #
/[Pp]ackages/
!/[Pp]ackages/manifest.json
!/[Pp]ackages/packages-lock.json